{
  "manifest_version": "0.3",
  "name": "Avanquest PDF API",
  "display_name": "Avanquest PDF API Extension",
  "version": "1.0.5",
  "description": "MCP server for the Avanquest PDF API, offering scalable tools for PDF conversion, merging, compression, splitting, and advanced document processing automation.",
  "long_description": "MCP server enabling Claude Desktop to access powerful PDF tools via the Avanquest PDF API. Features include converting PDFs to multiple formats and back, merging and splitting files, compression, page editing, password protection, watermarking, and advanced analysis of tags, forms, signatures, and attachments.",
  "author": {
    "name": "Avanquest Software",
    "email": "pdfsupport@avanquest.com",
    "url": "https://developers.avanquest.com"
  },
  "homepage": "https://developers.avanquest.com",
  "icon": "icon.png",
  "server": {
    "type": "node",
    "entry_point": "dist/index.js",
    "mcp_config": {
      "command": "node",
      "args": [
        "${__dirname}/dist/index.js"
      ],
      "env": {
        "AVANQUEST_PDF_API_KEY": "${user_config.api_key}",
        "AVANQUEST_PDF_API_BASE_URL": "https://api-developers.avanquest.com"
      }
    }
  },
  "tools_generated": true,
  "user_config": {
    "api_key": {
      "type": "string",
      "title": "Avanquest API Key",
      "description": "Your key from https://developers.avanquest.com",
      "required": true,
      "sensitive": true
    }
  },
  "keywords": [
    "pdf",
    "pdf to word",
    "pdf to docx",
    "pdf to excel",
    "pdf to xlsx",
    "pdf to powerpoint",
    "pdf to pptx",
    "pdf to text",
    "pdf to txt",
    "convert",
    "convert to docx",
    "convert to xlsx",
    "convert to pptx",
    "merge",
    "split",
    "compress",
    "delete pages",
    "rotate pages"
  ],
  "license": "MIT",
  "privacy_policies": ["https://developers.avanquest.com/privacy-policy"],
  "support": "mailto:support@avanquest.com",
  "documentation": "https://developers.avanquest.com"
}

# Avanquest PDF API Configuration
# Copy this file to .env and fill in your actual values

# Required: Your Avanquest PDF API key
# Obtain from: https://developers.avanquest.com (or your API provider)
AVANQUEST_PDF_API_KEY=your-api-key-here

# Optional: API base URL
# Default: https://api-developers.avanquest.com
# Only change if using a different endpoint
AVANQUEST_PDF_API_BASE_URL=https://api-developers.avanquest.com